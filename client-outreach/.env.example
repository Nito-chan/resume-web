# Brevo API (https://app.brevo.com -> Settings -> API Keys)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=your-verified-sender@email.com

# Notifications (where you get reply alerts)
NOTIFICATION_EMAIL=your-notification@email.com

# Instagram
INSTAGRAM_USERNAME=your-instagram-username
